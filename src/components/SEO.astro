---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  articleSection?: string;
  tags?: string[];
  activePage?: string;
}

const siteUrl = 'https://reformat-houston.vercel.app';
const siteName = 'ReformaT Houston';

// Normalizar path: quitar trailing slash excepto en home
const normalizePath = (path: string): string => {
  if (path === '/') return '/';
  return path.replace(/\/$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
const canonicalPath = Astro.url.pathname; // Preserve trailing slash for canonical
const isEnglish = !currentPath.startsWith('/es');
const lang = isEnglish ? 'en' : 'es';
const locale = isEnglish ? 'en_US' : 'es_VE';
const alternateLocale = isEnglish ? 'es_VE' : 'en_US';

const {
  title,
  description,
  image = '',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'ReformaT Houston',
  articleSection,
  tags = [],
  activePage = ''
} = Astro.props;

const ogImage = image && image.startsWith('http')
  ? image
  : `${siteUrl}${image || '/images/og-default.webp'}`;

const canonicalUrl = `${siteUrl}${canonicalPath}`;

// Mapa de traducción de rutas para hreflang (sin trailing slash)
const routeMap: Record<string, string> = {
  '/': '/es',
  '/es': '/',
  '/services': '/es/servicios',
  '/es/servicios': '/services',
  '/services/kitchens': '/es/servicios/cocinas',
  '/es/servicios/cocinas': '/services/kitchens',
  '/services/bathrooms': '/es/servicios/banos',
  '/es/servicios/banos': '/services/bathrooms',
  '/services/whole-home': '/es/servicios/integrales',
  '/es/servicios/integrales': '/services/whole-home',
  '/services/electrical': '/es/servicios/electricidad',
  '/es/servicios/electricidad': '/services/electrical',
  '/services/plumbing': '/es/servicios/fontaneria',
  '/es/servicios/fontaneria': '/services/plumbing',
  '/services/painting': '/es/servicios/pintura-acabados',
  '/es/servicios/pintura-acabados': '/services/painting',
  '/services/wall-coverings': '/es/servicios/revestimientos',
  '/es/servicios/revestimientos': '/services/wall-coverings',
  '/services/flooring': '/es/servicios/suelos',
  '/es/servicios/suelos': '/services/flooring',
  '/services/pools': '/es/servicios/piscinas',
  '/es/servicios/piscinas': '/services/pools',
  '/projects': '/es/proyectos',
  '/es/proyectos': '/projects',
  '/contact': '/es/contacto',
  '/es/contacto': '/contact',
  '/blog': '/es/blog',
  '/es/blog': '/blog',
  '/blog/kitchen-remodel-cost-caracas-valencia-2026': '/blog/cuanto-cuesta-reforma-cocina-valencia',
  '/blog/porcelain-tile-vs-ceramic-tile-guide': '/blog/porcelanato-vs-ceramica',
  '/blog/remodel-budget-mistakes-avoid': '/blog/presupuesto-reforma-errores',
  '/blog/bathroom-remodel-carabobo-guide': '/blog/reformas-banos-carabobo',
  '/blog/kitchen-design-trends-2026': '/blog/tendencias-cocinas-2025',
  '/blog/cuanto-cuesta-reforma-cocina-valencia': '/blog/kitchen-remodel-cost-caracas-valencia-2026',
  '/blog/porcelanato-vs-ceramica': '/blog/porcelain-tile-vs-ceramic-tile-guide',
  '/blog/presupuesto-reforma-errores': '/blog/remodel-budget-mistakes-avoid',
  '/blog/reformas-banos-carabobo': '/blog/bathroom-remodel-carabobo-guide',
  '/blog/tendencias-cocinas-2025': '/blog/kitchen-design-trends-2026',
  '/privacy': '/es/privacidad',
  '/es/privacidad': '/privacy',
  '/terms': '/es/terminos',
  '/es/terminos': '/terms'
};

// Obtener path alternativo (otro idioma)
const getAlternatePath = (): string => {
  // Buscar en el mapa primero
  if (routeMap[currentPath]) {
    return routeMap[currentPath];
  }
  
  // Fallback: si es ruta en español, quitar /es; si es inglés, añadir /es
  if (isEnglish) {
    const withoutEs = currentPath.replace(/^\/es/, '') || '/';
    return withoutEs;
  } else {
    return currentPath === '/' ? '/es' : `/es${currentPath}`;
  }
};

const alternatePath = getAlternatePath();

// Paths para hreflang (siempre normalizados)
const esPath = isEnglish ? alternatePath : currentPath;
const enPath = isEnglish ? currentPath : alternatePath;

// Breadcrumbs para Schema
const breadcrumbItems = [];
breadcrumbItems.push({ name: isEnglish ? 'Home' : 'Inicio', url: isEnglish ? '/es' : '/' });

if (currentPath === '/blog' || currentPath === '/blog') {
  breadcrumbItems.push({ name: 'Blog', url: currentPath });
} else if (currentPath.startsWith('/blog/') || currentPath.startsWith('/blog/')) {
  breadcrumbItems.push({ name: 'Blog', url: isEnglish ? '/blog' : '/blog' });
  breadcrumbItems.push({ name: title.split('|')[0].trim(), url: currentPath });
} else if (currentPath === '/servicios' || currentPath === '/services') {
  breadcrumbItems.push({ name: isEnglish ? 'Services' : 'Servicios', url: currentPath });
} else if (currentPath.startsWith('/servicios/') || currentPath.startsWith('/services/')) {
  breadcrumbItems.push({ name: isEnglish ? 'Services' : 'Servicios', url: isEnglish ? '/services' : '/servicios' });
  breadcrumbItems.push({ name: title.split('|')[0].trim(), url: currentPath });
} else if (currentPath === '/proyectos' || currentPath === '/projects') {
  breadcrumbItems.push({ name: isEnglish ? 'Projects' : 'Proyectos', url: currentPath });
} else if (currentPath === '/contacto' || currentPath === '/contact') {
  breadcrumbItems.push({ name: isEnglish ? 'Contact' : 'Contacto', url: currentPath });
}

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": siteUrl,
  "inLanguage": lang,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/blog?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const areasServed = [
  { "@type": "City", "name": "Houston" },
  { "@type": "City", "name": "San Diego" },
  { "@type": "City", "name": "Naguanagua" },
  { "@type": "City", "name": "Guacara" },
  { "@type": "City", "name": "Los Guayos" },
  { "@type": "AdministrativeArea", "name": "Carabobo" },
  { "@type": "City", "name": "The Woodlands" },
  { "@type": "AdministrativeArea", "name": "Chacao" },
  { "@type": "AdministrativeArea", "name": "Baruta" },
  { "@type": "AdministrativeArea", "name": "El Hatillo" },
  { "@type": "AdministrativeArea", "name": "Sucre" },
  { "@type": "AdministrativeArea", "name": "Libertador" },
  { "@type": "City", "name": "La Guaira" }
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": siteName,
  "image": `${siteUrl}/images/logo-header.webp`,
  "url": isEnglish ? `${siteUrl}/en` : siteUrl,
  "telephone": "+584227997043",
  "email": "info@reformat-houston.com",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Avenida Bolívar, Centro Profesional",
    "addressLocality": "Houston",
    "addressRegion": "Carabobo",
    "postalCode": "2001",
    "addressCountry": "VE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 10.1620,
    "longitude": -68.0077
  },
  "areaServed": areasServed,
  "availableLanguage": [
    {
      "@type": "Language",
      "name": "English"
    },
    {
      "@type": "Language",
      "name": "Spanish"
    }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "18:00"
  },
  "sameAs": [siteUrl]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": `${siteUrl}${item.url}`
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title.split('|')[0].trim(),
  "description": description,
  "image": ogImage,
  "datePublished": publishedTime,
  "dateModified": modifiedTime || publishedTime,
  "author": {
    "@type": "Organization",
    "name": siteName,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": siteName,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/logo-header.webp`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "inLanguage": lang,
  "articleSection": articleSection,
  "keywords": tags.join(', ')
};
---

<!-- BASIC META -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="author" content={siteName} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />

<!-- LANGUAGE META -->
<meta http-equiv="content-language" content={lang} />
<meta name="language" content={lang} />
<meta name="geo.region" content="VE" />
<meta name="geo.placename" content="Houston, The Woodlands, Sugar Land, Katy, Texas" />
<meta name="geo.position" content="10.1620;-68.0077" />
<meta name="ICBM" content="10.1620, -68.0077" />

<!-- HREFLANG (con self-referencing) -->
<link rel="alternate" hreflang="es" href={`${siteUrl}${esPath}`} />
<link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
<link rel="alternate" hreflang="x-default" href={`${siteUrl}${esPath}`} />

<!-- OPEN GRAPH -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />
<meta property="og:locale:alternate" content={alternateLocale} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:image:type" content="image/webp" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

{type === 'article' && publishedTime && (
  <>
    <meta property="article:published_time" content={publishedTime} />
    <meta property="article:modified_time" content={modifiedTime || publishedTime} />
    <meta property="article:author" content={siteName} />
    <meta property="article:section" content={articleSection} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />

<!-- FAVICON -->
<link rel="icon" type="image/png" href="/favicon-v3.png" />
<link rel="apple-touch-icon" href="/favicon-v3.png" />
<meta name="theme-color" content="#0a0a0a" />

<!-- SCHEMA: WEBSITE -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<!-- SCHEMA: LOCAL BUSINESS -->
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

<!-- SCHEMA: BREADCRUMBS -->
{breadcrumbItems.length > 1 && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<!-- SCHEMA: ARTICLE (solo para posts del blog) -->
{type === 'article' && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}