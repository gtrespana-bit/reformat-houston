---
interface Props {
  name?: string;
  description?: string;
  serviceType: string;
  areaServed?: string | string[];
  image?: string;
  priceRange?: string;
}

const { 
  name = '', 
  description = '', 
  serviceType, 
  areaServed = ['Houston', 'The Woodlands', 'Sugar Land', 'Katy', 'Cypress', 'Spring', 'Tomball', 'Montrose', 'Houston Heights', 'River Oaks', 'Pearland', 'Bellaire', 'Memorial'], 
  image,
  priceRange = '$$$'
} = Astro.props;

// Convertir a array si es string
const areasArray = typeof areaServed === 'string' ? areaServed.split(',').map(s => s.trim()) : areaServed;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": serviceType,
  ...(name && { "name": name }),
  ...(description && { "description": description }),
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Reformat Houston",
    "url": "https://reformat-houston.com",
    "telephone": "+1-832-555-0100",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Houston, TX",
      "addressLocality": "Houston",
      "addressRegion": "TX",
      "postalCode": "77001",
      "addressCountry": "US"
    },
    "areaServed": areasArray.map((area: string) => ({
      "@type": "City",
      "name": area,
      "containedInPlace": {
        "@type": "AdministrativeArea",
        "name": "Texas"
      }
    })),
    "priceRange": priceRange,
    "hasMap": "https://www.google.com/maps/search/?api=1&query=Houston,TX",
    "sameAs": [
      "https://www.houzz.com/pro/reformat-houston",
      "https://www.linkedin.com/company/reformat-houston",
      "https://www.instagram.com/reformat_houston"
    ]
  },
  ...(image && { "image": `https://reformat-houston.com${image}` }),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "47",
    "bestRating": "5"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
