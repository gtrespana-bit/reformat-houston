---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const city = "Tomball";
const title = `Kitchen Remodeling in ${city} | Cabinet Refacing & Countertops`;
const description = `Transform your kitchen with premium remodeling services in ${city}. Expert cabinet refacing, countertop installation, and custom design. Free estimates!`;
const image = "/images/hero-lcp.webp";
const url = `https://reformat-houston.com/${city.toLowerCase().replace(/\s+/g, '-')}`;
---

<BaseLayout title={title} description={description} image={image} url={url}>
  <ServiceSchema serviceType="Kitchen Remodeling" area={city} />
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="badge">Serving {city} Since 2004</div>
      <h1>Kitchen Remodeling in {city}</h1>
      <p>Transform your kitchen with expert craftsmanship and premium materials</p>
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-primary">Get Free Estimate</a>
        <a href="tel:+18329290939" class="btn btn-outline">Call (832) 929-0939</a>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-content">
          <h2>Your Dream Kitchen Awaits in {city}</h2>
          <p>With over 20 years of experience serving the {city} community, we specialize in creating beautiful, functional kitchens that become the heart of your home.</p>
          <ul class="highlights">
            <li>✓ Licensed & Insured Professionals</li>
            <li>✓ Premium Quality Materials</li>
            <li>✓ On-Time Project Completion</li>
            <li>✓ 100% Satisfaction Guarantee</li>
          </ul>
        </div>
        <div class="intro-image">
          <img src="/images/cocina-800.webp" alt={`Kitchen remodeling in ${city}`} loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services">
    <div class="container">
      <h2>Our Kitchen Services in {city}</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🏠</div>
          <h3>Cabinet Refacing</h3>
          <p>Give your cabinets a fresh new look without full replacement</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✨</div>
          <h3>Countertop Installation</h3>
          <p>Premium granite, quartz, and marble countertops</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🎨</div>
          <h3>Custom Design</h3>
          <p>Tailored kitchen designs to match your style</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🔨</div>
          <h3>Full Remodeling</h3>
          <p>Complete kitchen transformations from start to finish</p>
        </div>
        <div class="service-card">
          <div class="service-icon">💡</div>
          <h3>Lighting Solutions</h3>
          <p>Modern lighting to enhance your kitchen ambiance</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🚰</div>
          <h3>Plumbing & Fixtures</h3>
          <p>Professional sink and faucet installation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="why-us">
    <div class="container">
      <h2>Why Choose Us in {city}?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-number">20+</div>
          <h3>Years Experience</h3>
          <p>Serving {city} homeowners since 2004</p>
        </div>
        <div class="feature-card">
          <div class="feature-number">500+</div>
          <h3>Projects Completed</h3>
          <p>Hundreds of satisfied customers</p>
        </div>
        <div class="feature-card">
          <div class="feature-number">100%</div>
          <h3>Satisfaction Rate</h3>
          <p>We don't finish until you're happy</p>
        </div>
        <div class="feature-card">
          <div class="feature-number">★</div>
          <h3>Top Rated</h3>
          <p>5-star reviews from local clients</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="container">
      <h2>Ready to Transform Your Kitchen?</h2>
      <p>Contact us today for a free, no-obligation estimate</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Get Free Estimate</a>
        <a href="tel:+18329290939" class="btn btn-outline-light">Call (832) 929-0939</a>
      </div>
    </div>
  </section>

  <style>
    .hero {
      position: relative;
      height: 650px;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url('/images/hero-lcp.webp') center/cover no-repeat;
      opacity: 0.15;
    }
    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to bottom, rgba(10,10,10,0.7) 0%, rgba(10,10,10,0.5) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      padding: 0 20px;
    }
    .badge {
      display: inline-block;
      background: #c9a961;
      color: #0a0a0a;
      padding: 8px 20px;
      border-radius: 50px;
      font-weight: 600;
      font-size: 14px;
      margin-bottom: 24px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    h1 {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      margin-bottom: 20px;
      line-height: 1.2;
    }
    .hero p {
      font-size: clamp(1.1rem, 2vw, 1.3rem);
      margin-bottom: 32px;
      opacity: 0.95;
    }
    .hero-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      padding: 16px 32px;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      font-size: 1rem;
    }
    .btn-primary {
      background: #c9a961;
      color: #0a0a0a;
    }
    .btn-primary:hover {
      background: #d4b475;
      transform: translateY(-2px);
    }
    .btn-outline {
      background: transparent;
      color: white;
      border: 2px solid white;
    }
    .btn-outline:hover {
      background: white;
      color: #0a0a0a;
    }
    .btn-outline-light {
      background: transparent;
      color: white;
      border: 2px solid white;
    }
    .btn-outline-light:hover {
      background: white;
      color: #0a0a0a;
    }
    .intro {
      padding: 100px 0;
      background: #f8f9fa;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }
    .intro-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .intro-content h2 {
      font-size: 2.5rem;
      color: #0a0a0a;
      margin-bottom: 24px;
    }
    .intro-content p {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #333;
      margin-bottom: 24px;
    }
    .highlights {
      list-style: none;
      padding: 0;
    }
    .highlights li {
      padding: 8px 0;
      color: #0a0a0a;
      font-weight: 500;
      font-size: 1.05rem;
    }
    .intro-image img {
      width: 100%;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
    .services {
      padding: 100px 0;
      background: white;
    }
    .services h2 {
      text-align: center;
      font-size: 2.5rem;
      color: #0a0a0a;
      margin-bottom: 60px;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
    }
    .service-card {
      background: #f8f9fa;
      padding: 40px 30px;
      border-radius: 12px;
      text-align: center;
      transition: all 0.3s ease;
      border: 1px solid #eee;
    }
    .service-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      border-color: #c9a961;
    }
    .service-icon {
      font-size: 3rem;
      margin-bottom: 20px;
      display: block;
    }
    .service-card h3 {
      font-size: 1.4rem;
      color: #0a0a0a;
      margin-bottom: 12px;
    }
    .service-card p {
      color: #666;
      line-height: 1.6;
    }
    .why-us {
      padding: 100px 0;
      background: #0a0a0a;
      color: white;
    }
    .why-us h2 {
      text-align: center;
      font-size: 2.5rem;
      margin-bottom: 60px;
      color: #c9a961;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
    }
    .feature-card {
      background: rgba(255,255,255,0.05);
      padding: 40px 30px;
      border-radius: 12px;
      text-align: center;
      border: 1px solid rgba(255,255,255,0.1);
      transition: all 0.3s ease;
    }
    .feature-card:hover {
      background: rgba(255,255,255,0.1);
      transform: translateY(-5px);
    }
    .feature-number {
      font-size: 3rem;
      font-weight: 700;
      color: #c9a961;
      margin-bottom: 16px;
      display: block;
    }
    .feature-card h3 {
      font-size: 1.3rem;
      margin-bottom: 12px;
      color: white;
    }
    .feature-card p {
      color: rgba(255,255,255,0.8);
      line-height: 1.6;
    }
    .cta {
      padding: 100px 0;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
      color: white;
      text-align: center;
    }
    .cta h2 {
      font-size: 2.5rem;
      margin-bottom: 16px;
      color: #c9a961;
    }
    .cta p {
      font-size: 1.2rem;
      margin-bottom: 40px;
      opacity: 0.9;
    }
    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }
    @media (max-width: 768px) {
      .hero {
        height: 550px;
      }
      .intro-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .hero-buttons,
      .cta-buttons {
        flex-direction: column;
        align-items: center;
      }
      .btn {
        width: 100%;
        max-width: 300px;
        text-align: center;
      }
    }
  </style>
</BaseLayout>
