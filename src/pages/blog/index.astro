---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const englishSlugs = [
  'kitchen-remodel-cost-houston-2026',
  'porcelain-tile-vs-ceramic-tile-guide',
  'remodel-budget-mistakes-avoid',
  'bathroom-remodel-houston-guide',
  'kitchen-design-trends-2026'
];

// Mapeo de slugs a imágenes locales -400 para cards
const cardImages = {
  'kitchen-remodel-cost-houston-2026': '/images/cocina-400.webp',
  'porcelain-tile-vs-ceramic-tile-guide': '/images/revestimientos-400.webp',
  'remodel-budget-mistakes-avoid': '/images/integrales-400.webp',
  'bathroom-remodel-houston-guide': '/images/bano-400.webp',
  'kitchen-design-trends-2026': '/images/cocina-400.webp'
};

const posts = await getCollection('blog');
const englishPosts = posts.filter(post => englishSlugs.includes(post.id));
const sortedPosts = englishPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog | Remodeling Tips & Design Ideas" description="Ideas, trends and practical guides for your home remodeling project in Houston, TX." activePage="blog">
  <header class="page-hero">
    <img
      src="/images/arquitectura-600.webp"
      alt="Home remodeling ideas and tips"
      fetchpriority="high"
      loading="eager"
      decoding="async"
      width="600"
      height="400"
      class="hero-lcp-img"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="hero-tag">Blog & Tips</span>
      <h1 class="page-title">Ideas for <span class="gold">Your Home</span></h1>
      <p class="page-subtitle">Tips, trends and practical guides to help you with your remodeling project in Houston.</p>
    </div>
  </header>

  <section class="blog-section">
    <div class="container">
      <div class="blog-grid">
        {sortedPosts.map(article => (
          <a href={`/blog/${article.id}`} class="blog-card">
            <div class="blog-img">
              <img
                src={cardImages[article.id] || article.data.image}
                alt={article.data.title}
                loading="lazy"
                width="400"
                height="267"
                decoding="async"
              />
              <span class="blog-category">{article.data.category}</span>
            </div>
            <div class="blog-content">
              <div class="blog-meta">
                <span>{article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span>• {article.data.readTime} read</span>
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.excerpt}</p>
              <span class="blog-link">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-wrapper">
      <h2 class="cta-title">Ready To Transform Your Space?</h2>
      <p class="cta-text">Request a free consultation and receive a detailed quote with no obligation.</p>
      <a href="/contact" class="btn-premium btn-primary-premium">
        <span class="btn-content">Get Free Quote</span>
        <span class="btn-border"></span>
        <span class="btn-shine"></span>
        <span class="btn-arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-lcp-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(10,10,10,0.85) 0%, rgba(20,20,20,0.75) 100%);
    z-index: 2;
  }
  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    max-width: 800px;
    padding: 0 20px;
  }
  .hero-tag {
    display: inline-block;
    background: rgba(201,169,97,0.15);
    border: 1px solid rgba(201,169,97,0.4);
    color: #C9A961;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 20px;
    letter-spacing: 0.5px;
  }
  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 15px;
    color: #fff;
  }
  .gold {
    color: #C9A961;
  }
  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255,255,255,0.85);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .blog-section {
    padding: 80px 0;
    background: #0f0f0f;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
  }
  .blog-card {
    background: #141414;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(201,169,97,0.1);
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    border-color: rgba(201,169,97,0.3);
  }
  .blog-img {
    position: relative;
    height: 267px;
    overflow: hidden;
  }
  .blog-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .blog-card:hover .blog-img img {
    transform: scale(1.08);
  }
  .blog-category {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(10,10,10,0.9);
    color: #C9A961;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .blog-content {
    padding: 25px;
  }
  .blog-meta {
    display: flex;
    gap: 10px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 12px;
  }
  .blog-content h3 {
    font-size: 1.35rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 12px 0;
    line-height: 1.4;
  }
  .blog-content p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin: 0 0 15px 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-link {
    color: #C9A961;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .blog-link:hover {
    opacity: 0.8;
  }
  .cta-section {
    padding: 80px 20px;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
  }
  .cta-wrapper {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 15px;
  }
  .cta-text {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 30px;
    line-height: 1.6;
  }
  .btn-premium {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background: transparent;
    border: 1px solid #C9A961;
    color: #C9A961;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .btn-premium:hover {
    background: #C9A961;
    color: #0a0a0a;
  }
  .btn-content {
    position: relative;
    z-index: 2;
  }
  .btn-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(201,169,97,0.3);
    border-radius: 8px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.5; }
  }
  .btn-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(201,169,97,0.2), transparent);
    animation: shine 3s infinite;
  }
  @keyframes shine {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  .btn-arrow {
    margin-left: 8px;
    transition: transform 0.3s;
  }
  .btn-premium:hover .btn-arrow {
    transform: translateX(5px);
  }
</style>
