---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageData = {
  title: "Kitchen & Bathroom Remodeling in The Woodlands, TX | Reformat Houston",
  description: "Expert home remodeling services in The Woodlands, TX. Specializing in kitchen renovations, bathroom upgrades, and whole-home transformations for luxury living.",
  keywords: "Kitchen Remodeling The Woodlands, Bathroom Renovation The Woodlands, Home Remodeler The Woodlands, Luxury Remodeling Texas, Reformat Houston",
  canonical: "/the-woodlands/",
  locale: "en",
  area: "The Woodlands"
};

const serviceDetails = {
  name: "Reformat Houston - The Woodlands",
  areaServed: "The Woodlands, TX",
  description: "Premium remodeling services tailored for The Woodlands community. We understand the unique architectural styles and high standards of homeowners in this prestigious area.",
  address: {
    streetAddress: "Serving The Woodlands Area",
    addressLocality: "The Woodlands",
    addressRegion: "TX",
    postalCode: "77380",
    addressCountry: "US"
  },
  geo: {
    latitude: "30.1658",
    longitude: "-95.4613"
  }
};
---

<BaseLayout title={pageData.title} description={pageData.description} keywords={pageData.keywords} canonical={pageData.canonical} locale={pageData.locale}>
  <main class="pt-24 pb-12 bg-gray-50">
    <!-- Hero Section with Background -->
    <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden mb-16">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-900/80 to-blue-700/60 z-10"></div>
      <img 
        src="/images/the-woodlands-hero.jpg" 
        alt="Luxury home remodeling in The Woodlands Texas"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="relative z-20 text-center px-4 max-w-5xl mx-auto">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Expert Remodeling in <br/><span class="text-blue-300">The Woodlands</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-100 max-w-3xl mx-auto leading-relaxed">
          Transform your home with premium renovation services designed for the sophisticated lifestyle of The Woodlands community.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-white text-blue-900 font-bold py-4 px-10 rounded-full hover:bg-gray-100 transition duration-300 shadow-lg text-lg">
            Get Your Free Estimate
          </a>
          <a href="/services" class="border-2 border-white text-white font-bold py-4 px-10 rounded-full hover:bg-white/10 transition duration-300 text-lg">
            View Our Services
          </a>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4">
      <!-- Content Section -->
      <section class="bg-white rounded-2xl shadow-xl p-8 md:p-12 mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-8">Why Choose Reformat Houston for Your Woodlands Home?</h2>
        <p class="text-lg text-gray-700 mb-6 leading-relaxed">
          Living in The Woodlands means enjoying a unique blend of natural beauty and modern luxury. Your home deserves a remodeling partner who understands the specific architectural standards and lifestyle expectations of this prestigious community. 
        </p>
        <p class="text-lg text-gray-700 mb-8 leading-relaxed">
          From custom kitchen renovations that become the heart of your family gatherings to spa-like bathroom retreats that offer relaxation after a long day, our team delivers craftsmanship that matches the quality of life in The Woodlands. We navigate local HOA requirements and building codes seamlessly, ensuring your project is both beautiful and compliant.
        </p>
        
        <div class="grid md:grid-cols-2 gap-10 mt-10">
          <div class="bg-gray-50 p-8 rounded-xl">
            <h3 class="text-2xl font-semibold text-gray-900 mb-4">Our Local Expertise</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Deep understanding of The Woodlands architectural styles</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Experience with local HOA guidelines and permits</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Premium materials suited for Texas humidity</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Transparent pricing and detailed timelines</span>
              </li>
            </ul>
          </div>
          <div class="bg-gray-50 p-8 rounded-xl">
            <h3 class="text-2xl font-semibold text-gray-900 mb-4">Services Offered</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Luxury Kitchen Remodeling</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Master Bathroom Renovations</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Whole Home Transformations</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-gray-700">Custom Flooring & Finishes</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="text-center bg-gradient-to-r from-blue-600 to-blue-800 text-white rounded-2xl p-10 md:p-12 mb-12 shadow-2xl">
        <h2 class="text-4xl font-bold mb-6">Ready to Upgrade Your Woodlands Home?</h2>
        <p class="text-xl mb-8 opacity-90 max-w-2xl mx-auto">
          Schedule your free consultation today and discover how we can bring your vision to life.
        </p>
        <a href="/contact" class="inline-block bg-white text-blue-700 font-bold py-4 px-12 rounded-full hover:bg-gray-100 transition duration-300 shadow-lg text-xl">
          Get Your Free Estimate
        </a>
      </section>
    </div>
  </main>

  <ServiceSchema 
    name={serviceDetails.name}
    areaServed={serviceDetails.areaServed}
    description={serviceDetails.description}
    streetAddress={serviceDetails.address.streetAddress}
    addressLocality={serviceDetails.address.addressLocality}
    addressRegion={serviceDetails.address.addressRegion}
    postalCode={serviceDetails.address.postalCode}
    addressCountry={serviceDetails.address.addressCountry}
    latitude={serviceDetails.geo.latitude}
    longitude={serviceDetails.geo.longitude}
  />
</BaseLayout>
