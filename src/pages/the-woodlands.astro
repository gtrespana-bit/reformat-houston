---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageData = {
  title: "Kitchen & Bathroom Remodeling in The Woodlands, TX | Reformat Houston",
  description: "Expert home remodeling services in The Woodlands, TX. Specializing in luxury kitchens, spa bathrooms, and whole-home renovations. Serving Montgomery County for over 20 years.",
  keywords: "Kitchen Remodeling The Woodlands, Bathroom Renovation The Woodlands, Home Remodeler The Woodlands, Luxury Remodeling Texas, Reformat Houston",
  canonical: "/the-woodlands/",
  locale: "en",
  area: "The Woodlands"
};

const content = {
  heroTitle: "Premier Remodeling in The Woodlands",
  heroSubtitle: "Transform your home with expert craftsmanship tailored to The Woodlands' unique architectural style.",
  introTitle: "Expert Remodeling in The Woodlands, Texas",
  introText: "The Woodlands is a prestigious master-planned community known for its lush forests, top-rated schools, and elegant homes. Residents value quality, sustainability, and sophisticated design. We understand the specific needs of Woodlands homeowners, from managing humidity to preserving the natural aesthetic of the area. Our team has been serving this community for over two decades, delivering exceptional results that exceed expectations.",
  servicesTitle: "Our Premium Services in The Woodlands",
  services: [
    { title: "Custom Kitchen Renovations", desc: "High-end finishes, custom cabinetry, and innovative layouts designed for modern living." },
    { title: "Luxury Spa Bathrooms", desc: "Create your personal retreat with premium fixtures, heated floors, and elegant tile work." },
    { title: "Whole Home Transformations", desc: "Comprehensive renovations that seamlessly blend style, function, and structural integrity." },
    { title: "Flooring Installation", desc: "Hardwood, tile, and luxury vinyl options perfect for Texas climate conditions." },
    { title: "Painting & Fine Finishes", desc: "Professional painting services with attention to every detail and edge." },
    { title: "Outdoor Living Spaces", desc: "Covered patios, outdoor kitchens, and entertainment areas for year-round enjoyment." }
  ],
  whyChooseUsTitle: "Why The Woodlands Trusts Reformat Houston",
  whyChooseUs: [
    "Over 20 years serving The Woodlands community",
    "Licensed, bonded, and insured in Texas",
    "Expertise in luxury and custom home renovations",
    "Transparent pricing and detailed project timelines",
    "Dedicated project managers for seamless communication",
    "Deep understanding of local building codes and HOA requirements"
  ],
  ctaTitle: "Ready to Transform Your Home?",
  ctaText: "Schedule Your Free Consultation in The Woodlands",
  ctaSubtext: "Serving The Woodlands, Conroe, Shenandoah, and surrounding Montgomery County areas."
};
---

<BaseLayout
  title={pageData.title}
  description={pageData.description}
  activePage="services"
>
  <!-- Hero Section -->
  <div class="relative h-[70vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/85 to-gray-800/75 z-10"></div>
    <img 
      src="/images/woodlands-hero.jpg" 
      alt="Luxury home remodeling in The Woodlands Texas" 
      class="absolute inset-0 w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
    />
    <div class="relative z-20 text-center text-white px-4 max-w-6xl mx-auto mt-20">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight tracking-tight drop-shadow-2xl">
        {content.heroTitle}
      </h1>
      <p class="text-xl md:text-2xl lg:text-3xl mb-10 max-w-4xl mx-auto font-light text-gray-200 leading-relaxed">
        {content.heroSubtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="/contact" 
          class="inline-block bg-white text-gray-900 px-10 py-5 rounded-none font-bold text-lg hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-2xl border-2 border-white"
        >
          Get Your Free Estimate
        </a>
        <a 
          href="/services" 
          class="inline-block border-2 border-white text-white px-10 py-5 rounded-none font-bold text-lg hover:bg-white hover:text-gray-900 transition-all duration-300 shadow-2xl"
        >
          Explore Our Services
        </a>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    
    <!-- Area Introduction -->
    <section class="mb-24">
      <div class="text-center max-w-5xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-8 leading-tight">
          {content.introTitle}
        </h2>
        <div class="w-32 h-1.5 bg-blue-600 mx-auto mb-10"></div>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed max-w-4xl mx-auto">
          {content.introText}
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="mb-24">
      <h3 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-16">
        {content.servicesTitle}
      </h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {content.services.map((service) => (
          <div class="bg-white p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-gray-100 group hover:-translate-y-2">
            <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-700 mb-6 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-3">{service.title}</h4>
            <p class="text-gray-600 leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="mb-24 bg-gradient-to-br from-gray-50 to-gray-100 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-7xl mx-auto">
        <h3 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-16">
          {content.whyChooseUsTitle}
        </h3>
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-6 max-w-5xl mx-auto">
          {content.whyChooseUs.map((reason) => (
            <div class="flex items-start space-x-4 bg-white p-6 rounded-lg shadow-md">
              <div class="flex-shrink-0 w-10 h-10 bg-green-600 rounded-full flex items-center justify-center mt-1 shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <p class="text-gray-700 text-lg leading-relaxed font-medium">{reason}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="text-center bg-gradient-to-r from-blue-700 via-blue-600 to-blue-800 text-white py-24 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
      <div class="absolute inset-0 bg-black/10"></div>
      <div class="relative z-10 max-w-5xl mx-auto">
        <h3 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 leading-tight">
          {content.ctaTitle}
        </h3>
        <p class="text-xl md:text-2xl mb-12 text-blue-100 max-w-3xl mx-auto font-light">
          {content.ctaSubtext}
        </p>
        <a 
          href="/contact" 
          class="inline-block bg-white text-blue-700 px-12 py-6 rounded-none font-bold text-xl hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-2xl border-2 border-white"
        >
          {content.ctaText}
        </a>
        <p class="mt-8 text-blue-200 text-sm">Free consultation • No obligation • Licensed & Insured</p>
      </div>
    </section>
  </main>

  <ServiceSchema
    serviceType="Home Remodeling"
    areaServed={[content.areaServed, "Houston, TX", "Conroe, TX", "Shenandoah, TX", "Montgomery County, TX"]}
    latitude={30.1658}
    longitude={-95.4613}
  />
</BaseLayout>
