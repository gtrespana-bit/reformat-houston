---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageData = {
  title: "Kitchen & Bathroom Remodeling in The Woodlands, TX | Reformat Houston",
  description: "Expert home remodeling services in The Woodlands, TX. Specializing in luxury kitchens, spa bathrooms, and whole-home renovations. Serving Montgomery County for over 20 years.",
  keywords: "Kitchen Remodeling The Woodlands, Bathroom Renovation The Woodlands, Home Remodeler The Woodlands, Luxury Remodeling Texas, Reformat Houston",
  canonical: "/the-woodlands/",
  lang: "en",
  image: "/images/woodlands-remodeling.jpg",
  activePage: "areas"
};

const areaInfo = {
  name: "The Woodlands",
  type: "Master-Planned Community",
  description: "The Woodlands is a prestigious master-planned community known for its lush forests, top-rated schools, and elegant homes. Residents value quality, sustainability, and sophisticated design.",
  highlights: [
    "Top-rated schools in Montgomery County",
    "Luxury homes with forest preserves",
    "Upscale shopping at Market Street",
    "Award-winning restaurants and entertainment"
  ],
  services: [
    "Custom Kitchen Renovations",
    "Luxury Spa Bathrooms",
    "Whole Home Transformations",
    "Flooring Installation",
    "Painting & Fine Finishes",
    "Outdoor Living Spaces"
  ]
};
---

<BaseLayout {...pageData}>
  <main class="area-page">
    <section class="hero-area">
      <div class="container">
        <h1>Premier Remodeling in The Woodlands</h1>
        <p class="lead">Transform your home with expert craftsmanship tailored to The Woodlands' unique architectural style.</p>
        <a href="/contact" class="btn btn-primary">Get Your Free Estimate</a>
      </div>
    </section>

    <section class="area-content">
      <div class="container">
        <div class="content-grid">
          <div class="text-content">
            <h2>Expert Remodeling in The Woodlands, Texas</h2>
            <p>The Woodlands is a prestigious master-planned community known for its lush forests, top-rated schools, and elegant homes. Residents value quality, sustainability, and sophisticated design. We understand the specific needs of Woodlands homeowners, from managing humidity to preserving the natural aesthetic of the area. Our team has been serving this community for over two decades, delivering exceptional results that exceed expectations.</p>
            
            <p>From custom kitchen renovations with high-end finishes to luxury spa bathrooms with premium fixtures, we specialize in transformations that complement The Woodlands' distinctive character. Our expertise includes working within community guidelines while creating spaces that reflect your personal style.</p>

            <h3>Our Premium Services</h3>
            <ul class="services-list">
              {areaInfo.services.map((service) => (
                <li>{service}</li>
              ))}
            </ul>

            <h3>Why Choose Reformat Houston?</h3>
            <ul class="features-list">
              <li><strong>20+ Years Experience:</strong> Serving The Woodlands community for over two decades.</li>
              <li><strong>Luxury Expertise:</strong> Specialized in high-end custom renovations.</li>
              <li><strong>HOA Knowledge:</strong> Deep understanding of local building codes and HOA requirements.</li>
              <li><strong>Dedicated Management:</strong> Project managers for seamless communication.</li>
            </ul>
          </div>
          
          <div class="sidebar">
            <div class="cta-box">
              <h3>Ready to Transform Your Home?</h3>
              <p>Schedule Your Free Consultation in The Woodlands</p>
              <a href="/contact" class="btn btn-secondary">Contact Us Today</a>
            </div>
            
            <div class="local-info">
              <h4>Serving The Woodlands & Surrounding Areas</h4>
              <p>We proudly serve homeowners in The Woodlands, Conroe, Shenandoah, and surrounding Montgomery County areas.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="projects-teaser">
      <div class="container">
        <h2>Recent Projects in The Woodlands</h2>
        <p>See how we've helped Woodlands residents create their dream homes.</p>
        <a href="/projects" class="btn btn-outline">View Our Portfolio</a>
      </div>
    </section>
  </main>

  <ServiceSchema
    serviceType="Home Remodeling"
    areaServed={areaInfo.name}
    description={areaInfo.description}
    priceRange="$$$"
    latitude={30.1658}
    longitude={-95.4613}
  />
</BaseLayout>

<style>
  .area-page { padding-top: 80px; }
  .hero-area {
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/woodlands-hero.jpg');
    background-size: cover;
    background-position: center;
    color: white;
    padding: 100px 0;
    text-align: center;
  }
  .hero-area h1 { font-size: 3rem; margin-bottom: 20px; }
  .area-content { padding: 80px 0; }
  .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; }
  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
    .hero-area h1 { font-size: 2rem; }
  }
  .services-list, .features-list { list-style: none; padding: 0; }
  .services-list li, .features-list li { padding: 10px 0; border-bottom: 1px solid #eee; }
  .features-list li strong { color: #2c3e50; }
  .cta-box { background: #f8f9fa; padding: 30px; border-radius: 8px; margin-bottom: 30px; }
  .local-info { background: #fff; padding: 20px; border: 1px solid #e9ecef; border-radius: 8px; }
  .projects-teaser { background: #2c3e50; color: white; padding: 60px 0; text-align: center; }
</style>
