---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageData = {
  title: "Home Remodeling in Katy TX | Reformat Houston",
  description: "Expert remodeling contractor serving Katy, Texas. Specializing in family home renovations, kitchen upgrades, and bathroom remodels for growing communities.",
  keywords: "Katy remodeling, home renovation Katy TX, kitchen remodel Katy, bathroom renovation Katy Texas, contractor Katy Houston",
  canonical: "/katy/",
  lang: "en",
  image: "/images/katy-remodeling.jpg",
  activePage: "areas"
};

const areaInfo = {
  name: "Katy",
  type: "City",
  description: "Katy is a thriving suburb west of Houston, known for its excellent schools, family-friendly atmosphere, and rapid growth. We specialize in updating homes to meet the needs of modern families in this dynamic community.",
  highlights: [
    "Top-rated Katy ISD schools",
    "Master-planned communities with amenities",
    "Strong sense of community and family values",
    "Growing commercial and retail development"
  ],
  services: [
    "Kitchen Expansions and Remodels",
    "Master Bathroom Renovations",
    "Game Room and Media Room Additions",
    "Covered Patios and Outdoor Kitchens",
    "Flooring Updates Throughout Home"
  ]
};
---

<BaseLayout {...pageData}>
  <main class="area-page">
    <section class="hero-area">
      <div class="container">
        <h1>Expert Home Remodeling in Katy, Texas</h1>
        <p class="lead">Transforming homes for families in one of Houston's fastest-growing suburbs.</p>
        <a href="/contact" class="btn btn-primary">Get Your Free Estimate</a>
      </div>
    </section>

    <section class="area-content">
      <div class="container">
        <div class="content-grid">
          <div class="text-content">
            <h2>Remodeling Katy Homes for Growing Families</h2>
            <p>At Reformat Houston, we understand why families choose Katy. With top-rated schools, safe neighborhoods, and a strong community spirit, Katy offers an exceptional quality of life. Our renovations help you maximize your home's potential as your family grows.</p>
            
            <p>From expanding kitchens for busy family meals to creating game rooms for Texas weekends, we know what Katy homeowners need. Our team has extensive experience working in master-planned communities like Cinco Ranch, Seven Meadows, and Grand Lakes, understanding both architectural guidelines and homeowner expectations.</p>

            <h3>Our Katy Services</h3>
            <ul class="services-list">
              {areaInfo.services.map((service) => (
                <li>{service}</li>
              ))}
            </ul>

            <h3>Why Choose Reformat Houston?</h3>
            <ul class="features-list">
              <li><strong>Katy Expertise:</strong> Familiar with local communities and regulations.</li>
              <li><strong>Family Focus:</strong> Designs that work for real family life.</li>
              <li><strong>Quality Value:</strong> Smart investments that increase home value.</li>
              <li><strong>Reliable Service:</strong> On-time, on-budget project completion.</li>
            </ul>
          </div>
          
          <div class="sidebar">
            <div class="cta-box">
              <h3>Ready to Update Your Katy Home?</h3>
              <p>Schedule a consultation with our Katy remodeling specialists.</p>
              <a href="/contact" class="btn btn-secondary">Contact Us Today</a>
            </div>
            
            <div class="local-info">
              <h4>Serving Katy & Surrounding Areas</h4>
              <p>We proudly serve homeowners in Katy, Cinco Ranch, Fulshear, Richmond, and nearby western suburbs.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="projects-teaser">
      <div class="container">
        <h2>Recent Projects in Katy</h2>
        <p>See how we've helped Katy families create their dream homes.</p>
        <a href="/projects" class="btn btn-outline">View Our Portfolio</a>
      </div>
    </section>
  </main>

  <ServiceSchema
    serviceType="Home Remodeling"
    areaServed={areaInfo.name}
    description={areaInfo.description}
    priceRange="$$$"
    latitude={29.7858}
    longitude={-95.8244}
  />
</BaseLayout>

<style>
  .area-page { padding-top: 80px; }
  .hero-area {
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/katy-hero.jpg');
    background-size: cover;
    background-position: center;
    color: white;
    padding: 100px 0;
    text-align: center;
  }
  .hero-area h1 { font-size: 3rem; margin-bottom: 20px; }
  .area-content { padding: 80px 0; }
  .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; }
  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
    .hero-area h1 { font-size: 2rem; }
  }
  .services-list, .features-list { list-style: none; padding: 0; }
  .services-list li, .features-list li { padding: 10px 0; border-bottom: 1px solid #eee; }
  .features-list li strong { color: #2c3e50; }
  .cta-box { background: #f8f9fa; padding: 30px; border-radius: 8px; margin-bottom: 30px; }
  .local-info { background: #fff; padding: 20px; border: 1px solid #e9ecef; border-radius: 8px; }
  .projects-teaser { background: #2c3e50; color: white; padding: 60px 0; text-align: center; }
</style>
