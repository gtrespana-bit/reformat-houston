  <!-- THERMAL BREAK TECHNOLOGY -->
  <section class="technical-section">
    <div class="container">
      <h2 class="section-title">Thermal Break Technology:<br><span class="text-gold">The Secret to Efficiency</span></h2>
      
      <div class="tech-grid">
        <div class="tech-content">
          <h3>What is Thermal Break?</h3>
          <p>In traditional windows and doors, metal frames conduct heat and cold directly from outside to inside. A "thermal break" is an insulating barrier inserted between the interior and exterior aluminum profiles, dramatically reducing energy transfer.</p>
          
          <div class="benefits-grid">
            <div class="benefit-card">
              <div class="benefit-icon">❄️</div>
              <h4>Summer Savings</h4>
              <p>Keeps cool air inside, reducing AC costs by up to 40%</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">🔥</div>
              <h4>Winter Efficiency</h4>
              <p>Prevents heat loss, lowering heating bills significantly</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">🔇</div>
              <h4>Noise Reduction</h4>
              <p>Blocks external noise for a quieter interior</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">💧</div>
              <h4>Condensation Control</h4>
              <p>Prevents moisture buildup and mold growth</p>
            </div>
          </div>
        </div>
        
        <div class="tech-diagram">
          <div class="diagram-box">
            <div class="diagram-label">Outside (Hot)</div>
            <div class="diagram-layer layer-1">Glass Pane</div>
            <div class="diagram-layer layer-2">Air Gap / Argon</div>
            <div class="diagram-layer layer-3">Glass Pane</div>
            <div class="diagram-layer layer-4 thermal-break" style="background: linear-gradient(90deg, #c9a961, #fff, #c9a961);">Thermal Break Barrier</div>
            <div class="diagram-layer layer-5">Interior Frame</div>
            <div class="diagram-label">Inside (Cool)</div>
          </div>
          <p class="diagram-caption">Cross-section of a European thermal break window system</p>
        </div>
      </div>

      <!-- Energy Efficiency Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number text-gold">40%</div>
          <div class="stat-label">Energy Savings</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-gold">R-50</div>
          <div class="stat-label">Insulation Value</div>
        </div>
        <div class="stat-card">
