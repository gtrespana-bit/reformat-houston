---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageTitle = "The European Standard: Why Quality Beats Speed";
const pageDescription = "Discover why the European construction model delivers superior quality, energy efficiency, and longevity compared to the US standard. See the difference in materials, techniques, and results.";
---

<BaseLayout title={pageTitle} description={pageDescription} lang="en">
  <ServiceSchema 
    serviceName="European Construction Standards"
    serviceType="Construction Methodology"
    description="Comparing European and US construction standards for superior quality and efficiency."
  />

  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="badge">Quality Over Speed</span>
      <h1>The European Standard:<br/><span class="text-gold">Why Quality Beats Speed</span></h1>
      <p class="hero-subtitle">For centuries, European builders have prioritized longevity and precision. It's time to bring that same standard to Houston.</p>
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-primary">Get a Premium Quote</a>
        <a href="tel:+18329560797" class="btn btn-outline">Call Now</a>
      </div>
    </div>
  </section>

  <!-- INTRO COMPARISON -->
  <section class="comparison-intro section-padding">
    <div class="container">
      <div class="grid-2-col">
        <div class="content-col">
          <h2 class="section-title">Two Different Philosophies</h2>
          <p class="lead-text">The American construction model often prioritizes speed and cost-cutting, leading to homes that deteriorate within decades. The European model, refined over centuries, focuses on durability, energy efficiency, and timeless craftsmanship.</p>
          <p>At <strong>Reformat Houston</strong>, we don't just build; we restore the art of construction by applying rigorous European standards to every project in Texas.</p>
          
          <div class="stat-grid">
            <div class="stat-card">
              <span class="stat-number text-gold">50+</span>
              <span class="stat-label">Years Lifespan Difference</span>
            </div>
            <div class="stat-card">
              <span class="stat-number text-gold">40%</span>
              <span class="stat-label">More Energy Efficient</span>
            </div>
            <div class="stat-card">
              <span class="stat-number text-gold">0%</span>
              <span class="stat-label">Tolerance for Defects</span>
            </div>
          </div>
        </div>
        <div class="image-col">
          <div class="image-wrapper">
            <img src="/images/hero-lcp.webp" alt="European vs US Construction Comparison" loading="lazy" />
            <div class="image-badge">Timeless Quality</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- KEY DIFFERENCES GRID -->
  <section class="differences-section section-padding bg-light">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-title">Key Differences Explained</h2>
        <p class="section-subtitle">See exactly where the methods diverge and why it matters for your home.</p>
      </div>

      <div class="comparison-grid">
        <!-- Card 1: Materials -->
        <div class="diff-card">
          <div class="diff-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c9a961" stroke-width="2">
              <path d="M3 21h18M5 21V7l8-4 8 4v14M8 21v-9a4 4 0 0 1 4-4v0a4 4 0 0 1 4 4v9"/>
            </svg>
          </div>
          <h3>Material Quality</h3>
          <div class="vs-container">
            <div class="us-side">
              <span class="label bad">US Standard</span>
              <p>Lightweight drywall, hollow core doors, thin vinyl flooring, particle board cabinets.</p>
            </div>
            <div class="eu-side">
              <span class="label good">European Standard</span>
              <p>Solid plaster walls, solid wood doors, natural stone/ceramic, plywood/hardwood cabinetry.</p>
            </div>
          </div>
        </div>

        <!-- Card 2: Insulation -->
        <div class="diff-card">
          <div class="diff-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c9a961" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Insulation & Efficiency</h3>
          <div class="vs-container">
            <div class="us-side">
              <span class="label bad">US Standard</span>
              <p>Minimal insulation, single-pane windows, air leaks, high energy bills.</p>
            </div>
            <div class="eu-side">
              <span class="label good">European Standard</span>
              <p>Thick continuous insulation, triple-glazed windows, airtight sealing, passive house principles.</p>
            </div>
          </div>
        </div>

        <!-- Card 3: Structural Integrity -->
        <div class="diff-card">
          <div class="diff-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c9a961" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <h3>Structural Integrity</h3>
          <div class="vs-container">
            <div class="us-side">
              <span class="label bad">US Standard</span>
              <p>Wood framing prone to rot/mold, nail guns over screws, fast assembly with less precision.</p>
            </div>
            <div class="eu-side">
              <span class="label good">European Standard</span>
              <p>Steel reinforced concrete or high-grade timber, screw-fastened, precision engineered joints.</p>
            </div>
          </div>
        </div>

        <!-- Card 4: Finishes -->
        <div class="diff-card">
          <div class="diff-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c9a961" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3>Finishes & Details</h3>
          <div class="vs-container">
            <div class="us-side">
              <span class="label bad">US Standard</span>
              <p>Visible nail holes, uneven paint, gaps in trim, plastic fixtures.</p>
            </div>
            <div class="eu-side">
              <span class="label good">European Standard</span>
              <p>Flush finishes, hand-sanded surfaces, custom joinery, metal/glass fixtures.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS SECTION -->
  <section class="benefits-section section-padding">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-title">The Tangible Benefits</h2>
        <p class="section-subtitle">What you gain by choosing the European approach for your Houston home.</p>
      </div>

      <div class="benefits-grid">
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Lower Energy Bills</h4>
          <p>Superior insulation and airtight construction can reduce heating/cooling costs by up to 40%.</p>
        </div>
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Healthier Indoor Air</h4>
          <p>Better ventilation systems and non-toxic materials prevent mold and improve air quality.</p>
        </div>
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Noise Reduction</h4>
          <p>Denser materials and better sealing create a quiet sanctuary amidst city noise.</p>
        </div>
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Higher Resale Value</h4>
          <p>Homes built to higher standards retain value longer and attract discerning buyers.</p>
        </div>
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Disaster Resistance</h4>
          <p>Robust construction withstands Houston storms and humidity far better than standard builds.</p>
        </div>
        <div class="benefit-item">
          <div class="check-icon">✓</div>
          <h4>Timeless Aesthetics</h4>
          <p>Classic proportions and quality materials never go out of style.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MATERIALS DEEP DIVE: MASONRY & CONCRETE -->
  <section class="materials-deep-dive section-padding bg-light">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-title">The Foundation of Durability: Masonry & Concrete</h2>
        <p class="section-subtitle">While US homes rely on wood framing, European standards prioritize masonry, block, and reinforced concrete for unmatched strength.</p>
      </div>

      <div class="masonry-grid">
        <!-- Block Walls -->
        <div class="masonry-card">
          <div class="masonry-image">
            <img src="/images/katy-hero.jpg" alt="Concrete Block Construction" loading="lazy" />
          </div>
          <div class="masonry-content">
            <h3>Concrete Block Walls (CMU)</h3>
            <p><strong>US Standard:</strong> Wood studs with drywall. Prone to rot, mold, termites, and fire damage. Lifespan: 30-50 years before major issues.</p>
            <p><strong>European/Our Standard:</strong> Reinforced concrete masonry units (CMU) or clay brick. Impervious to pests, fire-resistant, and structurally superior.</p>
            <ul class="tech-list">
              <li>✓ Compressive strength: 2,000+ PSI vs wood's 500 PSI</li>
              <li>✓ Thermal mass regulates indoor temperature naturally</li>
              <li>✓ Sound transmission class (STC) 50+ vs wood's STC 35</li>
              <li>✓ Zero organic material = zero mold food source</li>
            </ul>
          </div>
        </div>

        <!-- Reinforced Concrete -->
        <div class="masonry-card reverse">
          <div class="masonry-image">
            <img src="/images/memorial-hero.jpg" alt="Reinforced Concrete Structure" loading="lazy" />
          </div>
          <div class="masonry-content">
            <h3>Reinforced Concrete Structures</h3>
            <p><strong>US Standard:</strong> Nail-gun assembled lumber. Weak connections, vulnerable to hurricanes and shifting foundations.</p>
            <p><strong>European/Our Standard:</strong> Steel-reinforced concrete poured into forms. Creates a monolithic structure that moves as one unit.</p>
            <ul class="tech-list">
              <li>✓ Rebar grid: #4 bars @ 12" OC minimum</li>
              <li>✓ Concrete mix: 4,000 PSI minimum compressive strength</li>
              <li>✓ Hurricane resistance: Withstands 150+ mph winds</li>
              <li>✓ Flood resilience: Survives immersion without structural damage</li>
            </ul>
          </div>
        </div>

        <!-- Brick Veneer vs Structural Brick -->
        <div class="masonry-card">
          <div class="masonry-image">
            <img src="/images/river-oaks-hero.jpg" alt="Structural Brick Work" loading="lazy" />
          </div>
          <div class="masonry-content">
            <h3>Structural Brick & Stone</h3>
            <p><strong>US Standard:</strong> Thin brick veneer glued to plywood. Purely cosmetic, falls off, no structural value.</p>
            <p><strong>European/Our Standard:</strong> Full-depth structural brick or natural stone load-bearing walls.</p>
            <ul class="tech-list">
              <li>✓ Thickness: 4-6 inches solid masonry vs ½ inch veneer</li>
              <li>✓ Mortar joints: Tooled and sealed for water tightness</li>
              <li>✓ Weep holes and flashings engineered for drainage</li>
              <li>✓ Lifespan: 100+ years with zero maintenance</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THERMAL BREAK TECHNOLOGY -->
  <section class="thermal-break-section section-padding">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-title">Thermal Break Technology: The Secret to Efficiency</h2>
        <p class="section-subtitle">How European windows and doors stop energy transfer, saving you 40% on HVAC costs.</p>
      </div>

      <div class="thermal-grid">
        <div class="thermal-content">
          <h3>What is a Thermal Break?</h3>
          <p>In standard aluminum or steel frames, metal conducts heat/cold directly from outside to inside. A <strong>thermal break</strong> is a non-conductive barrier (usually polyamide or reinforced plastic) inserted between the interior and exterior metal profiles.</p>
          
          <div class="efficiency-box">
            <h4>Performance Comparison</h4>
            <div class="efficiency-row">
              <span class="label">Standard Aluminum Window:</span>
              <span class="value bad">U-Factor 1.2 - 1.8 (High Heat Loss)</span>
            </div>
            <div class="efficiency-row">
              <span class="label">Thermal Break Window:</span>
              <span class="value good">U-Factor 0.15 - 0.30 (Minimal Heat Loss)</span>
            </div>
            <div class="efficiency-row highlight">
              <span class="label">Energy Savings:</span>
              <span class="value best">Up to 40% Reduction in HVAC Costs</span>
            </div>
          </div>

          <h4>Benefits in Houston Climate:</h4>
          <ul class="benefit-list-detailed">
            <li>
              <strong>Summer:</strong> Prevents 100°F+ outdoor heat from radiating into your cooled interior. Your AC runs less, lasts longer.
            </li>
            <li>
              <strong>Winter:</strong> Keeps interior warmth trapped inside during rare cold snaps. No "cold spots" near windows.
            </li>
            <li>
              <strong>Condensation Control:</strong> Eliminates interior condensation that leads to mold growth on sills and frames.
            </li>
            <li>
              <strong>Comfort:</strong> Interior frame surface stays within 5°F of room temperature, eliminating drafts.
            </li>
          </ul>
        </div>

        <div class="thermal-diagram">
          <div class="diagram-box">
            <div class="diagram-label top">Exterior Hot (100°F)</div>
            <div class="frame-outer"></div>
            <div class="thermal-barrier"></div>
            <div class="frame-inner"></div>
            <div class="diagram-label bottom">Interior Cool (72°F)</div>
            <div class="legend">
              <div class="legend-item"><span class="dot red"></span> Heat Flow Stopped</div>
              <div class="legend-item"><span class="dot blue"></span> Thermal Barrier</div>
            </div>
          </div>
          <p class="caption">Diagram: Heat transfer is blocked by the internal thermal barrier, maintaining indoor comfort.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section section-padding">
    <div class="container text-center">
      <h2 class="section-title">Ready to Upgrade Your Standard?</h2>
      <p class="section-subtitle max-w-2xl mx-auto">Don't settle for the typical American build. Experience the Reformat Houston difference, where European precision meets Texas hospitality.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary btn-lg">Request Free Consultation</a>
        <a href="tel:+18329560797" class="btn btn-outline btn-lg">Call (832) 956-0797</a>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      position: relative;
      height: 70vh;
      min-height: 600px;
      display: flex;
      align-items: center;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
      overflow: hidden;
    }
    .hero-overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.7) 100%);
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
      color: white;
      padding: 2rem;
    }
    .hero-content h1 {
      font-size: 3.5rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      color: white;
    }
    .hero-subtitle {
      font-size: 1.25rem;
      opacity: 0.9;
      margin-bottom: 2rem;
      line-height: 1.6;
    }
    .section-padding {
      padding: 5rem 1.5rem;
    }
    .grid-2-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      color: #0a0a0a;
      margin-bottom: 1rem;
    }
    .bg-light .section-title, .bg-dark .section-title {
      color: white;
    }
    .lead-text {
      font-size: 1.125rem;
      line-height: 1.8;
      color: #4a4a4a;
      margin-bottom: 1.5rem;
    }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3rem;
    }
    .stat-card {
      text-align: center;
      padding: 2rem;
      background: white;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .stat-number {
      display: block;
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }
    .stat-label {
      font-size: 0.875rem;
      color: #666;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .image-wrapper {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }
    .image-wrapper img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.5s ease;
    }
    .image-wrapper:hover img {
      transform: scale(1.05);
    }
    .image-badge {
      position: absolute;
      bottom: 20px;
      left: 20px;
      background: #c9a961;
      color: #0a0a0a;
      padding: 0.5rem 1rem;
      font-weight: 700;
      border-radius: 4px;
      font-size: 0.875rem;
    }
    .comparison-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }
    .diff-card {
      background: white;
      padding: 2.5rem;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .diff-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .diff-icon {
      margin-bottom: 1.5rem;
    }
    .diff-card h3 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      color: #0a0a0a;
    }
    .vs-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .us-side, .eu-side {
      padding: 1rem;
      border-radius: 6px;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .us-side {
      background: #f9f9f9;
      border-left: 3px solid #ccc;
    }
    .eu-side {
      background: #fdfcf5;
      border-left: 3px solid #c9a961;
    }
    .label {
      display: block;
      font-weight: 700;
      font-size: 0.75rem;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
    }
    .label.bad { color: #999; }
    .label.good { color: #c9a961; }
    
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }
    .benefit-item {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    .check-icon {
      width: 40px;
      height: 40px;
      background: #c9a961;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      font-weight: bold;
      margin-bottom: 1rem;
    }
    .benefit-item h4 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
      color: #0a0a0a;
    }
    .benefit-item p {
      color: #666;
      line-height: 1.6;
    }
    .feature-list {
      list-style: none;
      padding: 0;
      margin: 2rem 0;
    }
    .feature-list li {
      font-size: 1.125rem;
      margin-bottom: 1rem;
      color: #e0e0e0;
    }
    .gold-bullet {
      color: #c9a961;
      font-weight: bold;
      margin-right: 0.5rem;
    }
    .cta-section {
      background: linear-gradient(135deg, #0a0a0a 0%, #2a2a2a 100%);
      color: white;
    }
    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 2rem;
      flex-wrap: wrap;
    }
    
    @media (max-width: 768px) {
      .hero-content h1 { font-size: 2.5rem; }
      .grid-2-col { grid-template-columns: 1fr; gap: 2rem; }
      .stat-grid { grid-template-columns: 1fr; }
      .section-title { font-size: 2rem; }
      .cta-buttons { flex-direction: column; }
      .btn-lg { width: 100%; text-align: center; }
    }
  </style>
</BaseLayout>
