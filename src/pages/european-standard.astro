---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const pageTitle = "The European Standard: Why Quality Beats Speed";
const pageDescription = "Discover why the European construction model delivers superior quality, energy efficiency, and longevity compared to the US standard.";
---

<BaseLayout title={pageTitle} description={pageDescription} lang="en">
  <ServiceSchema serviceName="European Construction Standards" serviceType="Construction Methodology" description="Comparing European and US construction standards." />

  <!-- HERO SECTION WITH REAL IMAGE -->
  <section class="hero-section">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="badge-gold">Quality Over Speed</span>
      <h1 class="hero-title">
        The <span class="gold-text">European Standard</span><br/>
        Why Quality Beats Speed
      </h1>
      <p class="hero-subtitle">
        While American construction prioritizes fast completion, European building methods focus on longevity, 
        energy efficiency, and superior craftsmanship. Discover why the European approach delivers 
        3x better performance and 50+ years of durability.
      </p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Request Free Consultation</a>
        <a href="tel:8329560797" class="btn-secondary">Call (832) 956-0797</a>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      position: relative;
      height: 700px;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: url('/images/hero-lcp.webp') center/cover no-repeat;
      z-index: 1;
    }
    .hero-overlay {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: linear-gradient(135deg, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.85) 50%, rgba(201,169,97,0.3) 100%);
      z-index: 2;
    }
    .hero-content {
      position: relative;
      z-index: 3;
      max-width: 900px;
      color: white;
      margin: 0 auto;
      padding: 0 24px;
    }
    .badge-gold {
      display: inline-block;
      background: linear-gradient(135deg, #c9a961 0%, #b8960f 100%);
      color: #0a0a0a;
      padding: 10px 24px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 24px;
    }
    .hero-title {
      font-size: clamp(36px, 5vw, 64px);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 24px;
      color: white;
    }
    .gold-text { color: #c9a961 !important; }
    .hero-subtitle {
      font-size: clamp(18px, 2vw, 22px);
      line-height: 1.7;
      color: rgba(255,255,255,0.9);
      margin-bottom: 40px;
      max-width: 700px;
    }
    .cta-buttons {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-primary {
      background: linear-gradient(135deg, #c9a961 0%, #b8960f 100%);
      color: #0a0a0a;
      padding: 16px 36px;
      border-radius: 8px;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s ease;
      display: inline-block;
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(201,169,97,0.4);
    }
    .btn-secondary {
      background: transparent;
      color: white;
      border: 2px solid #c9a961;
      padding: 14px 34px;
      border-radius: 8px;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s ease;
      display: inline-block;
    }
    .btn-secondary:hover {
      background: #c9a961;
      color: #0a0a0a;
    }
  </style>
</BaseLayout>
