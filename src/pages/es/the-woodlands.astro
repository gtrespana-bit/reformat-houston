---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';

const pageData = {
  title: "Remodelación de Cocinas y Baños en The Woodlands, TX | Reformat Houston",
  description: "Servicios expertos de remodelación en The Woodlands, TX. Especializados en cocinas de lujo, baños tipo spa y renovaciones completas del hogar. Sirviendo a Montgomery County por más de 20 años.",
  keywords: "Remodelación de Cocinas The Woodlands, Renovación de Baños The Woodlands, Remodelador de Casas The Woodlands, Reformas de Lujo Texas, Reformat Houston",
  canonical: "/es/the-woodlands/",
  lang: "es",
  image: "/images/cocina-800.webp",
  activePage: "areas"
};

const areaInfo = {
  name: "The Woodlands",
  type: "Comunidad Planificada",
  description: "The Woodlands es una prestigiosa comunidad planificada conocida por sus exuberantes bosques, escuelas de primer nivel y hogares elegantes. Los residentes valoran la calidad, la sostenibilidad y el diseño sofisticado.",
  highlights: [
    "Escuelas de primer nivel en Montgomery County",
    "Hogares de lujo con reservas forestales",
    "Compras exclusivas en Market Street",
    "Restaurantes y entretenimiento premiados"
  ],
  services: [
    "Renovaciones Personalizadas de Cocinas",
    "Baños de Lujo Tipo Spa",
    "Transformaciones Completas del Hogar",
    "Instalación de Pisos",
    "Pintura y Acabados Finos",
    "Espacios de Vida al Aire Libre"
  ]
};
---

<BaseLayout {...pageData}>
  <main class="area-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-overlay"></div>
      <div class="hero-content container">
        <span class="hero-badge">Sirviendo The Woodlands Desde 2004</span>
        <h1>Remodelación Premium de Cocinas y Baños en The Woodlands, TX</h1>
        <p class="hero-lead">Transforme su hogar con artesanía experta adaptada al estilo arquitectónico único y los estándares de lujo de The Woodlands.</p>
        <div class="hero-buttons">
          <a href="/es/contacto" class="btn btn-primary btn-lg">Obtenga Su Presupuesto Gratis</a>
          <a href="tel:+13463979026" class="btn btn-outline-light btn-lg">(346) 397-9026</a>
        </div>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="intro-section">
      <div class="container">
        <div class="intro-grid">
          <div class="intro-content">
            <h2>Remodelación Experta en The Woodlands, Texas</h2>
            <p class="intro-text">The Woodlands es una prestigiosa comunidad planificada conocida por sus exuberantes bosques, escuelas de primer nivel y hogares elegantes. Los residentes valoran la calidad, la sostenibilidad y el diseño sofisticado.</p>
            <p>Entendemos las necesidades específicas de los propietarios de The Woodlands, desde manejar la humedad hasta preservar la estética natural del área. Nuestro equipo ha estado sirviendo a esta comunidad durante más de dos décadas, ofreciendo resultados excepcionales que superan las expectativas.</p>
            
            <div class="highlights-grid">
              <div class="highlight-item">
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>Escuelas de primer nivel en Montgomery County</span>
              </div>
              <div class="highlight-item">
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>Hogares de lujo con reservas forestales</span>
              </div>
              <div class="highlight-item">
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>Compras exclusivas en Market Street</span>
              </div>
              <div class="highlight-item">
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>Restaurantes y entretenimiento premiados</span>
              </div>
            </div>
          </div>
          
          <div class="intro-image">
            <img src="/images/cocina-800.webp" alt="Remodelación de cocina de lujo en The Woodlands" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="services-section">
      <div class="container">
        <div class="section-header">
          <span class="section-badge">Nuestros Servicios</span>
          <h2>Servicios Premium de Remodelación</h2>
          <p>Soluciones integrales para su hogar de lujo</p>
        </div>
        
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="20" width="48" height="36" rx="2" fill="currentColor" opacity="0.1"/>
                <path d="M12 28h40M12 36h40M20 44h24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M32 8v12M28 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Renovaciones Personalizadas de Cocinas</h3>
            <p>Cocinas personalizadas con gabinetes premium, encimeras de cuarzo y electrodomésticos de alta gama adaptados a su estilo de vida.</p>
          </div>
          
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="12" y="16" width="40" height="32" rx="2" fill="currentColor" opacity="0.1"/>
                <circle cx="32" cy="28" r="6" stroke="currentColor" stroke-width="2"/>
                <path d="M20 40h24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Baños de Lujo Tipo Spa</h3>
            <p>Transforme su baño en un spa personal con duchas de cristal sin marco, tinas independientes y accesorios premium.</p>
          </div>
          
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 20v24h32V20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 28h40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <circle cx="32" cy="16" r="4" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <h3>Transformaciones Completas del Hogar</h3>
            <p>Renovaciones completas del hogar que combinan perfectamente funcionalidad con diseño elegante en toda su propiedad.</p>
          </div>
          
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="16" y="16" width="32" height="32" stroke="currentColor" stroke-width="2"/>
                <path d="M16 32h32M32 16v32" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <h3>Instalación de Pisos</h3>
            <p>Pisos premium de madera, baldosa y vinilo de lujo instalados con precisión para belleza y durabilidad duraderas.</p>
          </div>
          
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 20l24 24M44 20L20 44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <rect x="16" y="16" width="32" height="32" rx="2" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <h3>Pintura y Acabados Finos</h3>
            <p>Pintura profesional y acabados detallados que elevan la estética de su hogar con ejecución impecable.</p>
          </div>
          
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 44V28l20-12 20 12v16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M20 44v-8h24v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Espacios de Vida al Aire Libre</h3>
            <p>Patios personalizados, cocinas al aire libre y áreas de entretenimiento diseñadas para el clima y estilo de vida de Texas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="why-section">
      <div class="container">
        <div class="section-header">
          <span class="section-badge">Por Qué Elegirnos</span>
          <h2>La Diferencia Reformat Houston</h2>
          <p>Lo que nos distingue de otros contratistas en The Woodlands</p>
        </div>
        
        <div class="why-grid">
          <div class="why-card">
            <div class="why-number">20+</div>
            <h3>Años de Excelencia</h3>
            <p>Sirviendo a la comunidad de The Woodlands con dedicación y experiencia durante más de dos décadas.</p>
          </div>
          
          <div class="why-card">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <h3>Experiencia en Lujo</h3>
            <p>Especializados en renovaciones personalizadas de alta gama con atención a cada detalle.</p>
          </div>
          
          <div class="why-card">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3>Conocimiento de HOA</h3>
            <p>Profundo conocimiento de los códigos de construcción locales y requisitos de HOA en The Woodlands.</p>
          </div>
          
          <div class="why-card">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h3>Gestión Dedicada</h3>
            <p>Gerentes de proyecto personales aseguran comunicación fluida de principio a fin.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para Transformar Su Hogar?</h2>
          <p>Programe su consulta gratuita con nuestro equipo experto que sirve a The Woodlands, Conroe, Shenandoah y las áreas circundantes de Montgomery County.</p>
          <div class="cta-buttons">
            <a href="/es/contacto" class="btn btn-white btn-lg">Obtenga Presupuesto Gratis</a>
            <a href="tel:+13463979026" class="btn btn-outline-white btn-lg">Llame al (346) 397-9026</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <ServiceSchema
    serviceType="Remodelación del Hogar"
    areaServed={areaInfo.name}
    description={areaInfo.description}
    priceRange="$$$"
    latitude={30.1658}
    longitude={-95.4613}
  />
</BaseLayout>

<style>
  /* Base Styles */
  .area-page { 
    padding-top: 0;
  }

  /* Hero Section - Full viewport height, no overlap */
  .hero-section {
    position: relative;
    height: 650px;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    margin-top: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('/images/hero-lcp.webp') center/cover no-repeat;
    opacity: 0.15;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 20px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    color: #fff;
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 24px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .hero-section h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    line-height: 1.2;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .hero-lead {
    font-size: clamp(16px, 2.5vw, 20px);
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: #c9a961;
    color: #0a0a0a;
    border: 2px solid #c9a961;
  }

  .btn-primary:hover {
    background: #b8964e;
    border-color: #b8964e;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(201, 169, 97, 0.3);
  }

  .btn-outline-light {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn-outline-light:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    transform: translateY(-2px);
  }

  /* Intro Section */
  .intro-section {
    padding: 80px 0;
    background: #fff;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 450px;
    gap: 60px;
    align-items: start;
  }

  .intro-content h2 {
    font-size: 32px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 24px;
    line-height: 1.3;
  }

  .intro-text {
    font-size: 18px;
    color: #4a5568;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .intro-content p {
    font-size: 16px;
    color: #4a5568;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 32px;
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: #f7fafc;
    border-radius: 8px;
    border-left: 3px solid #38a169;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    color: #38a169;
    flex-shrink: 0;
  }

  .highlight-item span {
    font-size: 15px;
    color: #2d3748;
    font-weight: 500;
    line-height: 1.4;
  }

  .intro-image {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  .intro-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
  }

  /* Services Section */
  .services-section {
    padding: 80px 0;
    background: #f7fafc;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 60px;
  }

  .section-badge {
    display: inline-block;
    background: rgba(201, 169, 97, 0.1);
    color: #c9a961;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .section-header h2 {
    font-size: 36px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .section-header p {
    font-size: 18px;
    color: #718096;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .service-card {
    background: #fff;
    padding: 32px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    border: 1px solid #e2e8f0;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }

  .service-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #c9a961 0%, #b8964e 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: #0a0a0a;
  }

  .service-icon svg {
    width: 28px;
    height: 28px;
  }

  .service-card h3 {
    font-size: 20px;
    font-weight: 600;
    color: #1a202c;
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .service-card p {
    font-size: 15px;
    color: #718096;
    line-height: 1.6;
  }

  /* Why Section */
  .why-section {
    padding: 80px 0;
    background: #fff;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .why-card {
    text-align: center;
    padding: 32px 24px;
    background: #f7fafc;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .why-card:hover {
    background: #fff;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .why-number {
    font-size: 48px;
    font-weight: 700;
    background: linear-gradient(135deg, #c9a961 0%, #b8964e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }

  .why-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #c9a961 0%, #b8964e 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #0a0a0a;
  }

  .why-icon svg {
    width: 28px;
    height: 28px;
  }

  .why-card h3 {
    font-size: 18px;
    font-weight: 600;
    color: #1a202c;
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .why-card p {
    font-size: 14px;
    color: #718096;
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 80px 0;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 36px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .cta-content p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-white {
    background: #c9a961;
    color: #0a0a0a;
    border: 2px solid #c9a961;
  }

  .btn-white:hover {
    background: #b8964e;
    border-color: #b8964e;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(201, 169, 97, 0.3);
  }

  .btn-outline-white {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    transform: translateY(-2px);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro-image {
      order: -1;
    }

    .intro-image img {
      height: 400px;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      height: 550px;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn-lg {
      width: 100%;
      max-width: 300px;
      text-align: center;
    }

    .highlights-grid {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
