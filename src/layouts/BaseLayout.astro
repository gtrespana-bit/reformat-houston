            <a
              href={item.href}
              class={[
                activePage === item.key ? 'active' : '',
                item.premium ? 'btn-nav-premium' : ''
              ].filter(Boolean).join(' ')}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        type="button"
        class="lang-switch-visible"
        data-current-lang={lang}
        aria-label={isSpanish ? 'Switch to English' : 'Cambiar a español'}
