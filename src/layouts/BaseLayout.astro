          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <main id="main-content">
<slot />
</main>

  <a href={`https://wa.me/18325550100?text=${whatsappText}`} target="_blank" class="whatsapp-float" aria-label={isSpanish ? 'Contactar por WhatsApp' : 'Contact via WhatsApp'} style="display:flex;align-items:center;justify-content:center;">
