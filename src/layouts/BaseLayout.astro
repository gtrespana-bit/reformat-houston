---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  activePage?: 'inicio' | 'servicios' | 'proyectos' | 'blog' | 'contacto' | 'home' | 'services' | 'projects' | 'contact';
  articleType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  articleSection?: string;
  tags?: string[];
}

const { 
  title, 
  description, 
  image = '', 
  activePage = '',
  articleType = 'website',
  publishedTime,
  modifiedTime,
  author,
  articleSection,
  tags
} = Astro.props;

const currentPath = Astro.url.pathname;
const isSpanish = currentPath.startsWith('/es');
const lang = isSpanish ? 'es' : 'en';

// Hreflang route mapping EN <-> ES
const enToEsMap: Record<string, string> = {
  '/': '/es/',
  '/services/': '/es/servicios/',
  '/services/kitchens/': '/es/servicios/cocinas/',
  '/services/bathrooms/': '/es/servicios/banos/',
  '/services/electrical/': '/es/servicios/electricidad/',
  '/services/plumbing/': '/es/servicios/fontaneria/',
  '/services/wall-coverings/': '/es/servicios/revestimientos/',
  '/services/flooring/': '/es/servicios/suelos/',
  '/services/pools/': '/es/servicios/piscinas/',
  '/services/whole-home/': '/es/servicios/integrales/',
  '/services/painting/': '/es/servicios/pintura-acabados/',
  '/contact/': '/es/contacto/',
  '/projects/': '/es/proyectos/',
  '/blog/': '/es/blog/',
  '/about-us/': '/es/sobre-nosotros/',
  '/privacy/': '/es/privacidad/',
  '/terms/': '/es/terminos/',
  // Location Pages
  '/the-woodlands/': '/es/the-woodlands/',
  '/sugar-land/': '/es/sugar-land/',
  '/river-oaks/': '/es/river-oaks/',
  '/houston-heights/': '/es/houston-heights/',
  '/montrose/': '/es/montrose/',
  '/memorial/': '/es/memorial/',
  '/katy/': '/es/katy/',
  '/pearland/': '/es/pearland/',
  '/spring/': '/es/spring/',
  '/conroe/': '/es/conroe/',
  '/cypress/': '/es/cypress/',
  '/tomball/': '/es/tomball/',
};

const esToEnMap: Record<string, string> = {
  '/es/': '/',
  '/es/servicios/': '/services/',
  '/es/servicios/cocinas/': '/services/kitchens/',
  '/es/servicios/banos/': '/services/bathrooms/',
  '/es/servicios/electricidad/': '/services/electrical/',
  '/es/servicios/fontaneria/': '/services/plumbing/',
  '/es/servicios/revestimientos/': '/services/wall-coverings/',
  '/es/servicios/suelos/': '/services/flooring/',
  '/es/servicios/piscinas/': '/services/pools/',
  '/es/servicios/integrales/': '/services/whole-home/',
  '/es/servicios/pintura-acabados/': '/services/painting/',
  '/es/contacto/': '/contact/',
  '/es/proyectos/': '/projects/',
  '/es/blog/': '/blog/',
  '/es/sobre-nosotros/': '/about-us/',
  '/es/privacidad/': '/privacy/',
  '/es/terminos/': '/terms/',
  // Location Pages
  '/es/the-woodlands/': '/the-woodlands/',
  '/es/sugar-land/': '/sugar-land/',
  '/es/river-oaks/': '/river-oaks/',
  '/es/houston-heights/': '/houston-heights/',
  '/es/montrose/': '/montrose/',
  '/es/memorial/': '/memorial/',
  '/es/katy/': '/katy/',
  '/es/pearland/': '/pearland/',
  '/es/spring/': '/spring/',
  '/es/conroe/': '/conroe/',
  '/es/cypress/': '/cypress/',
  '/es/tomball/': '/tomball/',
};

const siteBase = 'https://reformat-houston.com';

// Función auxiliar para normalizar paths (quitar/add trailing slash consistentemente)
const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.endsWith('/') ? path.slice(0, -1) : path;
};

const normalizedCurrentPath = normalizePath(currentPath);

// Función para obtener el href de cambio de idioma
const getLanguageHref = (path: string, toSpanish: boolean): string => {
  const normalized = normalizePath(path);
  
  if (toSpanish) {
    // De inglés a español
    if (normalized === '/') return `${siteBase}/es/`;
    
    // Verificar mapa explícito primero
    if (enToEsMap[normalized + '/']) {
      return `${siteBase}${enToEsMap[normalized + '/']}`;
    }
    if (enToEsMap[normalized]) {
      return `${siteBase}${enToEsMap[normalized]}`;
    }
    
    // Si es una ruta de ciudad genérica no mapeada
    const cityMatch = normalized.match(/^\/([a-z]+(?:-[a-z]+)*)$/);
    if (cityMatch && !normalized.includes('/services/') && !normalized.includes('/es/')) {
      return `${siteBase}/es/${normalized.slice(1)}/`;
    }
    
    // Default: añadir /es
    return `${siteBase}/es${normalized}/`;
  } else {
    // De español a inglés
    if (normalized === '/es' || normalized === '/es/') return `${siteBase}/`;
    
    // Verificar mapa explícito primero
    if (esToEnMap[normalized + '/']) {
      return `${siteBase}${esToEnMap[normalized + '/']}`;
    }
    if (esToEnMap[normalized]) {
      return `${siteBase}${esToEnMap[normalized]}`;
    }
    
    // Si es una ruta de ciudad genérica en español no mapeada
    const cityMatch = normalized.match(/^\/es\/([a-z]+(?:-[a-z]+)*)$/);
    if (cityMatch && !normalized.includes('/servicios/')) {
      return `${siteBase}/${normalized.replace('/es/', '')}/`;
    }
    
    // Default: quitar /es
    return `${siteBase}${normalized.replace('/es', '')}/`;
  }
};

const enHref = isSpanish ? getLanguageHref(currentPath, false) : `${siteBase}${currentPath}`;
const esHref = isSpanish ? `${siteBase}${currentPath}` : getLanguageHref(currentPath, true);

const whatsappText = isSpanish
  ? 'Hola,%20me%20interesa%20una%20consulta%20para%20mi%20proyecto'
  : 'Hello,%20I%20am%20interested%20in%20a%20consultation%20for%20my%20project';

const skipLinkText = isSpanish ? 'Saltar al contenido principal' : 'Skip to main content';
const menuLabel = isSpanish ? 'Abrir menú de navegación' : 'Open navigation menu';
const footerDesc = isSpanish
  ? 'Transformando espacios con excelencia desde 2005.'
  : 'Transforming spaces with excellence since 2005.';
const footerRights = isSpanish
  ? 'Todos los derechos reservados.'
  : 'All rights reserved.';
const footerLocations = isSpanish
  ? 'Houston, The Woodlands, Sugar Land, Katy y áreas circundantes.'
  : 'Houston, The Woodlands, Sugar Land, Katy and surrounding areas.';

const navItems = isSpanish
  ? [
      { label: 'Inicio', href: '/es', key: 'inicio' },
      { label: 'Servicios', href: '/es/servicios', key: 'servicios' },
      { label: 'Sobre Nosotros', href: '/es/sobre-nosotros', key: 'about' },
      { label: 'Proyectos', href: '/es/proyectos', key: 'proyectos' },
      { label: 'Blog', href: '/es/blog', key: 'blog' },
      { label: 'Contacto', href: '/es/contacto', key: 'contacto', premium: true }
    ]
  : [
      { label: 'Home', href: '/', key: 'home' },
      { label: 'Services', href: '/services', key: 'services' },
      { label: 'About Us', href: '/about-us', key: 'about' },
      { label: 'Projects', href: '/projects', key: 'projects' },
      { label: 'Blog', href: '/blog', key: 'blog' },
      { label: 'Contact', href: '/contact', key: 'contact', premium: true }
    ];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Preload fuentes críticas (woff2 self-hosted) -->
  <link rel="preload" href="/fonts/manrope-v15-latin-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-600.woff2" as="font" type="font/woff2" crossorigin />
