  <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-700.woff2" as="font" type="font/woff2" crossorigin />
<!-- Hreflang: indicar a Google las versiones en cada idioma -->
  <link rel="canonical" href={`${siteBase}${currentPath}`} />
  <link rel="alternate" hreflang="es" href={esHref} />
  <link rel="alternate" hreflang="en" href={enHref} />
  <link rel="alternate" hreflang="x-default" href={esHref} />

  
  <SEO 
    title={title}
    description={description}
    image={image}
    type={articleType}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    author={author}
    articleSection={articleSection}
    tags={tags}
    activePage={activePage}
  />

  <Analytics />
</head>

<body>
  <a href="#main-content" class="skip-link">{skipLinkText}</a>

  <nav id="navbar" class="nav" role="navigation" aria-label={isSpanish ? 'Menú principal' : 'Main navigation'}>
